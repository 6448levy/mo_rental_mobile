# Normalize line endings. Dart/Flutter uses LF; keep it canonical across OSes
# so editors/tools on Windows don't churn the diff with CRLF<->LF flips.
* text=auto eol=lf

# Windows-only scripts must stay CRLF
*.bat   text eol=crlf
*.ps1   text eol=crlf
*.cmd   text eol=crlf

# Treat common binary assets as binary (no EOL conversion / diffing)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   text
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.jar   binary
*.keystore binary
*.jks   binary
